# Remote Gateway Environment Variables
# Copy this file to .env and fill in your values.

# MCP Server
MCP_SERVER_NAME=revops-gateway
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# Data Source API Keys
# STRIPE_API_KEY=sk_live_...
# SNOWFLAKE_ACCOUNT=...
