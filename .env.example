# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# GitHub-backed notes tools
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=owner/inform-notes
GITHUB_BRANCH=main
# NOTES_PATH=notes  # folder inside GITHUB_REPO to store notes (default: "notes")

# Gateway server (optional overrides)
# MCP_SERVER_NAME=inform-gateway
# MCP_TRANSPORT=sse
# MCP_SERVER_PORT=8000
# TELEMETRY_DB_PATH=data/telemetry.db
